rules_version = '2';
service cloudfirestore {
  match /databases/{database}/documents {

    // Global default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.esAdmin == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Helpers ---

    function isValidUsuario(data) {
      return data.keys().hasAll(['uid', 'email', 'nombre', 'esAdmin']) &&
             data.uid is string &&
             data.email is string && data.email.size() <= 200 &&
             data.nombre is string && data.nombre.size() <= 300 &&
             data.esAdmin is bool;
    }

    function isValidProducto(data) {
      return data.keys().hasAll(['id', 'nombre', 'marca', 'categoria', 'genero', 'precio_regular', 'imagenes', 'descripcion', 'variantes']) &&
             data.id is string &&
             data.nombre is string && data.nombre.size() <= 200 &&
             data.marca is string && data.marca.size() <= 100 &&
             data.categoria is string &&
             data.genero is string && (data.genero == 'Men' || data.genero == 'Women') &&
             data.precio_regular is number && data.precio_regular > 0 &&
             (data.precio_descuento == null || (data.precio_descuento is number && data.precio_descuento > 0)) &&
             data.imagenes is list && data.imagenes.size() > 0 &&
             data.descripcion is string && data.descripcion.size() <= 2000 &&
             data.variantes is list;
    }

    function isValidPedido(data) {
      return data.keys().hasAll(['id', 'usuario_id', 'items', 'total', 'estado', 'fecha_creacion', 'direccion_envio']) &&
             data.id is string &&
             data.usuario_id is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.estado is string && (data.estado == 'pendiente' || data.estado == 'enviado' || data.estado == 'entregado') &&
             data.fecha_creacion is string &&
             data.direccion_envio is map;
    }

    function isValidCupon(data) {
      return data.keys().hasAll(['id', 'tipo', 'valor', 'fecha_expiracion', 'categoria_restringida']) &&
             data.id is string &&
             data.tipo is string && (data.tipo == 'porcentaje' || data.tipo == 'fijo') &&
             data.valor is number && data.valor > 0 &&
             data.fecha_expiracion is string &&
             (data.categoria_restringida == null || data.categoria_restringida is string);
    }

    function isValidHomeConfig(data) {
      return data.keys().hasAll(['id', 'banner1_texto', 'banner1_bg', 'banner2_texto', 'banner2_bg']) &&
             data.id is string &&
             data.banner1_texto is string && data.banner1_texto.size() <= 500 &&
             data.banner1_bg is string && data.banner1_bg.size() <= 30 &&
             data.banner2_texto is string && data.banner2_texto.size() <= 500 &&
             data.banner2_bg is string && data.banner2_bg.size() <= 30;
    }

    // --- Collections Rule Matchers ---

    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isUser(userId) && (
        !incoming().keys().hasAny(['esAdmin']) || incoming().esAdmin == false
      );
      allow update: if isUser(userId) && (
        (!incoming().keys().hasAny(['esAdmin']) && !existing().keys().hasAny(['esAdmin'])) ||
        incoming().esAdmin == existing().esAdmin
      );
      allow delete: if isAdmin();
    }

    match /productos/{productId} {
      allow read: if true; // Public catalogue
      allow create: if (isAdmin() || isValidProducto(incoming())) && isValidId(productId);
      allow update: if isAdmin() && isValidProducto(incoming()) && isValidId(productId);
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /pedidos/{pedidoId} {
      // Direct get or collections listing: ensure users can only list their own unless Admin
      allow get: if isSignedIn() && (resource.data.usuario_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.usuario_id == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidPedido(incoming()) && incoming().usuario_id == request.auth.uid && isValidId(pedidoId);
      allow update: if isSignedIn() && isValidPedido(incoming()) && (
        isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['estado'])
      );
      allow delete: if isAdmin() && isValidId(pedidoId);
    }

    match /cupones/{cuponId} {
      allow read: if true;
      allow create: if (isAdmin() || isValidCupon(incoming())) && isValidId(cuponId);
      allow update: if isAdmin() && isValidCupon(incoming()) && isValidId(cuponId);
      allow delete: if isAdmin() && isValidId(cuponId);
    }

    match /config/{configId} {
      allow read: if true;
      allow create: if (isAdmin() || (configId == 'home_cms' ? isValidHomeConfig(incoming()) : true));
      allow update: if isAdmin() && (configId == 'home_cms' ? isValidHomeConfig(incoming()) : true);
      allow delete: if isAdmin();
    }
  }
}
